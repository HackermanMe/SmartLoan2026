
@{
    ViewBag.Title = "Certificat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model EcoService.Models.EcoCerCertificateDataModel

<!----------------------------------------------------- Section styles -------------------------------------------------->

<style>
    body.modal-open {
        filter: blur(px);
        pointer-events: none;
        overflow: hidden;
        padding-right: 0 !important;
    }

    .success-modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: #F5F5F7;
        padding: 10px;
        border-radius: 10px;
        width: 600px;
        box-shadow: 0px 0px 10px rgba(0,0,0,0.3);
    }

    .close-btn {
        float: right;
        font-size: 27px;
        cursor: pointer;
        color: #B7B7B7;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .close-btn:hover {
            color: #000000;
        }

    .cancel-button {
        background-color: #B7B7B7;
        width: 280px;
        height: 45px;
        border-style: none;
        border-radius: 9px;
        font-size: 1rem;
        text-decoration: none;
        text-align: center;
        display: inline-block;
        line-height: 45px;
        margin-top: 10px;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .cancel-button:active {
            background-color: #999999 !important;
            transform: scale(0.95);
        }

        .cancel-button:hover {
            background-color: #B4B4B8;
        }

    .confirm-button {
        background-color: #0082bb;
        width: 180px;
        height: 45px;
        border-style: none;
        border-radius: 9px;
        font-size: 1rem;
        text-decoration: none;
        text-align: center;
        display: inline-block;
        line-height: 45px;
        margin-top: 10px;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .confirm-button:hover {
            background-color: #007bb1;
        }

        .confirm-button:active {
            background-color: #005f8c;
            transform: scale(0.95);
        }

    a:hover {
        text-decoration: none;
    }
</style>

<!----------------------------------------------------- Section html -------------------------------------------------->

<div class="container">
    <div class="card-header">
        Confirmation des informations
    </div>
    <div class="card-body">
        <h5 class="card-title"></h5>
        <p class="card-text">Les informations suivantes seront utilisées pour générer votre attestation de travail, Assurez-vous qu'elles sont correctes:</p>

        <div class="form-group mb-3">
            <label class="form-label">Nom:</label>
            <input value="@Model.Nom" class="form-control" placeholder="" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Prénoms:</label>
            <input value="@Model.Prenom" class="form-control" placeholder="" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Sexe:</label>
            <input value="@Model.Sexe" class="form-control" placeholder="" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Civilité:</label>
            <input value="@Model.Civilite" class="form-control" placeholder="" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Catégorie professionnelle:</label>
            <input value="@Model.CategorieProfessionnelle" class="form-control" placeholder="" readonly />
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Date de recrutement:</label>
            <input value="@Model.DateRecrutement" class="form-control" readonly />
            @*<input value="@Model.DateRecrutement?.ToString(" dd /MM/yyyy")" class="form-control" readonly />*@
        </div>
        <div>
            @Html.ActionLink("Retourner en arrière", "GenerateCertificate", "EcoCerCertificate", null, new { @class = "cancel-button text-white" })
            @Html.ActionLink("Confirmer", "CreateCertificate", "EcoCerCertificate", null, new { id = "confirmButton", @class = "confirm-button text-white" })

            @*  <a asp-controller="EcoCerCertificate" asp-action="GenerateCertificate" class="cancel-button text-white">Retourner en arrière</a> *@
            @* <a asp-action="CreateCertificate" class="confirm-button text-white" id="confirmButton">Confirmer</a> *@
        </div>
    </div>
</div>


@* success modal *@

<div id="successModal" class="success-modal" tabindex="-1">
    <div class="modal-content">
        <div class="d-flex justify-content-end ">
            <span class="close-btn" onclick="closeModal()">&times;</span>
        </div>

        <div>
            <div class="d-flex justify-content-center align-content-center align-items-center p-4">

                <p>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16" style="color:green">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                    </svg>
                    Votre demande d'attestation a été soumise avec succès!
                </p>
            </div>

            <div class="d-flex justify-content-end">
                <button id="okButton" class="btn btn-success">Ok</button>
            </div>
        </div>
    </div>
</div>

<!----------------------------------------------------- Section javascript -------------------------------------------------->

<script>
    document.getElementById("confirmButton").addEventListener("click", function (event) {
        event.preventDefault();

        fetch("/EcoCerCertificate/CreateCertificate", {
            method: "GET",
            headers: {
                "Content-Type": "application/json"
            }
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById("successModal").style.display = "flex";
                    document.body.classList.add("modal-open");
                } else {
                    alert(data.message)
                }
            })
            .catch(error => console.error("Error: ", error))
        //    fetch("/EcoCerCertificate/CreateCertificate", {
        //        method: "GET",
        //        headers: { "Content-Type": "application/json" }
        //    })
        //        .then(response => response.json())  // ← Transforme bien la réponse en JSON
        //        .then(data => {
        //            if (data.success) {
        //                alert("Certificat créé avec succès !");
        //            } else {
        //                console.error("Erreur:", data.error);
        //                alert("Erreur: " + data.error);
        //            }
        //        })
        //        .catch(error => console.error("Erreur réseau :", error));


    });

    document.getElementById("okButton").addEventListener("click", function () {
        document.getElementById("successModal").style.display = "none";
        document.body.classList.remove("modal-open");
        window.scrollTo(0, 0);
        //document.getElementById("confirmButton").disabled = true;
    });
</script>