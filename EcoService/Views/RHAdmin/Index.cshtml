@model System.Data.DataTable
@using System.Data;
@{
    ViewData["Title"] = "Administration";
}

<h5>Liste du Personnel</h5>

<div class="row">
    <div class="col-9">
        <form class="" id="searchForm" asp-action="Search" method="post">
            <div class="form-group has-search">
                <input class="form-control" id="searchTerm" type="text" name="searchTerm" placeholder="Rechercher..." onsubmit="return false;">
            </div>
        </form>
    </div>
    <div class="col-3 btn-group" role="group">
        <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            Ajouter
        </button>
        <ul class="dropdown-menu">
            <li>@Html.ActionLink("Ajouter Staff", "UploadStaff", "RHAdmin", null, new { @class = "dropdown-item" })</li>
            <li>@Html.ActionLink("Ajouter Prêts", "UploadLoans", "RHAdmin", null, new { @class = "dropdown-item" })</li>
        </ul>
    </div>
</div>

<table id="loansTable" class="table">
    <thead>
        <tr>
            <th>Matricule</th>
            <th>Nom & Prénoms</th>
            <th>Numéro de Compte</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="resultsTable">
        @foreach (DataRow row in Model.Rows)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => @row[0])</td>
                <td>@Html.DisplayFor(modelItem => @row[3]) @Html.DisplayFor(modelItem => @row[4])</td>
                <td>@Html.DisplayFor(modelItem => @row[5])</td>
                <td><a href="../RHAdmin/Simulation/@row[0]" class="btn btn-sm btn-primary">Simulation</a></td>
            </tr>
        }
    </tbody>
</table>

@section Scripts
{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script>
    $(document).ready(function () {
        $('#searchTerm').on('input', function () {
            var searchTerm = $(this).val();
            var resultsTable = $('#resultsTable');

            if (searchTerm === '') {
                resultsTable.empty(); // Vider le tableau si la barre de recherche est vide
                return;
            }

            $.ajax({
                url: '@Url.Action("Search", "RHAdmin")',
                type: 'POST',
                data: { searchTerm: searchTerm },
                success: function (data) {
                    resultsTable.empty();

                    if (data.length === 0) {
                        resultsTable.append('<tr><td colspan="5">Aucun résultat trouvé.</td></tr>');
                    } else {
                        data.forEach(function (staff) {
                            var row = '<tr>' +
                                '<td>' + staff["Matricule"] + '</td>' +
                                '<td>' + staff["Nom"]+ " " + staff["Prenom"] +'</td>' +
                                '<td>' + staff["NumeroCompte"] + '</td>' +
                                '<td><a href="/RHAdmin/Simulation/' + staff["Matricule"] + '">Simulation</a></td>' +
                                '</tr>';
                            resultsTable.append(row);
                        });
                    }
                },
                error: function () {
                    $('#resultsTable').html('<tr><td colspan="5">Une erreur s\'est produite lors de la recherche.</td></tr>');
                }
            });
        });
    });
    </script>
}