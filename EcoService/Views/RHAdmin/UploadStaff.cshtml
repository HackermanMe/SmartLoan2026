@{
    ViewData["Title"] = "Ajout du Staff";
}

<h1>Ajouter les Staffs</h1>

<form method="post" enctype="multipart/form-data" action="ImportStaffs">
    <div class="form-group">
        <label for="file">Choisir Fichier Excel:</label>
        <input type="file" name="file" id="file" class="form-control">
    </div>
    <button type="submit" class="btn btn-primary m3">Télécharger</button>

</form>
