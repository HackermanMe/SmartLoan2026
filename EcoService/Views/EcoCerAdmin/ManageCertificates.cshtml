<!--html des tableaux composants la page-->
<div class="d-flex justify-content-center flex-column align-content-center">
    <div>
        <p class="fs-5">Liste des attestations</p>
    </div>
    @*   <div class="">
            <input type="text" class="searchBar-input p-2 w-auto" placeholder="Rechercher..." id="certificateSearchInput" oninput="searchQuery();" />
        </div> *@
    <hr>
    @* Tableau des attestations en attente *@
    <div class="table-container" id="PendingSection">
        <h2>Attestations en attente de traitement...</h2>
        <div class="">
            <input type="text" class="searchBar-input p-2 w-auto" placeholder="Rechercher..." id="pendingCertificatesSearch" />
        </div>
        <table class="styled-table table-hover" id="pendingCertificatesTable">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Numéro de référence</th>
                    <th scope="col">Nom complet</th>
                    <th scope="col">Date de création</th>
                    <th scope="col">Statut</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody id="pendingCertificatesList">
                @{
                    var pendingCertificates = ViewBag.PendingCertificates;
                    if (pendingCertificates.Count == 0)
                    {
                        <tr class="">
                            <td colspan="6">
                                <div class="alert alert-info text-center mx-auto" role="alert">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16" style="margin-right: 6px;">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                                    </svg>
                                    Aucune nouvelle demande d'attestation n'a été soumise pour le moment...
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {

                        for (int i = 0; i < pendingCertificates.Count; i++)
                        {

                            var certificate = pendingCertificates[i];
            <tr class="clickable-row" data-id="@certificate.CdmId" onclick="openModal();editCertificate(@certificate.CdmId);">
                <td>@(i + 1)</td>
                <td>@certificate.RefNumber</td>
                <td>@certificate.Nom @certificate.Prenom</td>
                <!--<td>@*@certificate.CreationDate.ToString("dd/MM/yyyy")*@</td>-->
                <td>@certificate.CreationDate.ToString("dd/MM/yyyy", new System.Globalization.CultureInfo("fr-FR"))</td>
                <td><span class="badge bg-danger">En attente</span></td>
                <td>
                    <button class="validate-btn rounded btn btn-outline-success" id="validateButton" onclick="event.stopPropagation();validateCertificate();">
                        Valider
                    </button>
                </td>
            </tr>
                        }
                    }
                }

            </tbody>
        </table>

        <nav aria-label="Page navigation" id="pageNavigation">
            <ul class="pagination justify-content-center" id="pendingPagination">
                <li class="page-item">
                    <a class="page-link" id="prevPending">Précédent</a>
                </li>
                <li class="page-item"><a class="page-link" id="pendingPageInfo"></a></li>
                <li class="page-item">
                    <a class="page-link" id="nextPending">Suivant</a>
                </li>
            </ul>
        </nav>
    </div>

    @* Tableau des attestations validées *@
    <div class="table-container" id="ValidateSection">
        <h2>Attestations validées</h2>
        <div class="">
            <input type="text" class="searchBar-input p-2 w-auto" placeholder="Rechercher..." id="validateCertificatesSearch" />
