    /*script pour que la vue scroll directement sur le tableau d'attestations validées
    aucune attestation en attente n'existe*/
    window.onload = function () {
        if (document.querySelectorAll("tbody tr").length === 0) {
            document.querySelector("#ValidateSection").scrollIntoView({ behavior: "smooth" });
        }
    }

    function formatDateToInputFormat(dateString) {
        let date = new Date(dateString);
        let day = String(date.getDate()).padStart(2, '0');
        let month = String(date.getMonth() + 1).padStart(2, '0');
        let year = date.getFullYear();

        return `${year}-${month}-${day}`;
    }

    function formatDate(dateString) {
        let date = new Date(dateString);
        let day = String(date.getDate()).padStart(2, '0');
        let month = String(date.getMonth() + 1).padStart(2, '0');
        let year = date.getFullYear();

        return `${day}/${month}/${year}`;
    }

    /*Fonction qui ajoute un delai après la saisie de l'utilisateur avant l'appel des fonctions de recherche*/
    function debounce(func, delay) {
        let timer;
        return function (...args) {
            clearTimeout(timer);
            timer = setTimeout(() => {
                func.apply(this, args);
            }, delay);
        };
    }



    document.addEventListener("DOMContentLoaded", function () {
        let pendingPage = 1;
        let validatePage = 1;
        const rowsPerPage = 5;
        let pendingCertificates = [];
        let validateCertificates = [];

        document.querySelectorAll("#pendingCertificatesList tr").forEach(row => {
            //console.log(row.cells.length);
            if (row.cells.length > 1) {
                pendingCertificates.push({
                    CdmId: row.getAttribute("data-id"),
                    PositionNumber: row.cells[0].textContent,
                    RefNumber: row.cells[1].textContent,
                    NomEtPrenom: row.cells[2].textContent,
                    DateCreation: row.cells[3].textContent
                });
            }
        });

        document.querySelectorAll("#validateCertificatesList tr").forEach(row => {
            //console.log(row.cells.length);
            if (row.cells.length > 1) {
                validateCertificates.push({
                    CdmId: row.getAttribute("data-id"),
                    PositionNumber: row.cells[0].textContent,
                    RefNumber: row.cells[1].textContent,
                    NomEtPrenom: row.cells[2].textContent,
                    DateCreation: row.cells[3].textContent
                });
            }
        });

        function updateTable(type, html) {
            let tableBody;
            let currentPage;
            let data;
            let pageInfo;
            /*console.log("UpdateTable function got called!");
            console.log("pendingCertificates: ", pendingCertificates);
            console.log("validateCertificates: ", validateCertificates);*/
            if (type === "pending") {
                tableBody = document.getElementById("pendingCertificatesList");
                currentPage = pendingPage;
                data = pendingCertificates
                pageInfo = document.getElementById("pendingPageInfo")
            } else {
                tableBody = document.getElementById("validateCertificatesList");
                currentPage = validatePage;
                data = validateCertificates;
                pageInfo = document.getElementById("validatePageInfo");
            }

            tableBody.innerHTML = "";
            let start = (currentPage - 1) * rowsPerPage;
            let end = currentPage * rowsPerPage;
            let paginatedData = data.slice(start, end);
            if (html.length === 0) {
                if (paginatedData.length > 0) {

                    paginatedData.forEach((certificate, index) => {
                        tableBody.innerHTML += type === "pending" ? `<tr class="clickable-row" data-id="${certificate.CdmId}" onclick="openModal();editCertificate(${certificate.CdmId});">
                                <td>${index + 1}</td>
                                <td>${certificate.RefNumber}</td>
                                <td>${certificate.NomEtPrenom}</td>
                                <td>${certificate.DateCreation}</td>
                                <td><span class="badge bg-danger">En attente</span></td>
                                <td>
                                    <button class="validate-btn rounded  btn btn-outline-success" id="validateButton" onclick="event.stopPropagation();">
                                        Valider
                                    </button>
                                </td>
                            </tr>`: `<tr class="" data-id="${certificate.CdmId}">
                                <td>${index + 1}</td>
                                <td>${certificate.RefNumber}</td>
                                <td>${certificate.NomEtPrenom}</td>
                                <td>${certificate.DateCreation}</td>
                                <td><span class="badge bg-success">Validé</span></td>
                                <td>
                                   <button class="download-btn rounded-pill" onclick="event.stopPropagation(); getCertificatePdf(${certificate.CdmId});">
       <svg xmlns="http://www.w3.org/2000/svg"  width="16" height="16" fill="currentColor" class="bi bi-file-earmark" viewBox="0 0 16 16">
           <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
       </svg>
       Générer
                                    </button>
                                </td>
                            </tr>`
                    });
                } else {
                    tableBody.innerHTML += type === "pending" ? `  <tr class="">
                  <td colspan="6">
                      <div class="alert alert-info text-center mx-auto" role="alert">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16" style="margin-right: 6px;">
                              <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                              <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                          </svg>
                          Aucune nouvelle demande d'attestation n'a été soumise pour le moment...
                      </div>
                  </td>
              </tr>`: `<tr class="">
                  <td colspan="6">
                      <div class="alert alert-info text-center mx-auto" role="alert">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16" style="margin-right: 6px;">
                              <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                              <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                          </svg>
                          Aucune attestation n'a encore été validée
                      </div>
                  </td>
              </tr>`;
                }

                pageInfo.textContent = paginatedData.length > 0 ? `Page ${currentPage} sur ${Math.ceil(data.length / rowsPerPage)}` : "Page 1 sur 1"
            } else {
                tableBody.innerHTML = html;
            }
        }
        function setUpPagination(type) {
            document.getElementById(type === "pending" ? "prevPending" : "prevValidate")
                .addEventListener("click", function () {
                    if (type === "pending" && pendingPage > 1) {
                        pendingPage--;
                    } else if (type === "validate" && validatePage > 1) {
                        validatePage--
                    }

                    updateTable(type, "");
                });

            document.getElementById(type === "pending" ? "nextPending" : "nextValidate")
                .addEventListener("click", function () {
                    //console.log("length: " + pendingCertificates.length);
                    let lastPendingPage = Math.ceil(pendingCertificates.length / rowsPerPage);
                    let lastValidatePage = Math.ceil(validateCertificates.length / rowsPerPage);
                    if (type === "pending" && pendingPage < lastPendingPage) {
                        pendingPage++;
                    } else if (type === "validate" && validatePage < lastValidatePage) {
                        validatePage++
                    }

                    updateTable(type, "");
                });
        }

        updateTable("pending", "");
        updateTable("validate", "");
        setUpPagination("pending");
        setUpPagination("validate");

        document.getElementById("pendingCertificatesSearch").addEventListener("input", debounce(function () {
            let param = this.value.trim();
            //console.log(param);
            let html = ""
            fetch(`/EcoCerAdmin/SearchPendingCertificates?param=${param}`)
                .then(response => response.json())
                .then(data => {
                    /*console.log("Full response: ",data);
                    console.log("Fetch result: "+JSON.stringify(data.Result,null,2));
                    console.log("Result length: "+data.Result.length);*/
                    if (data.Result.length === 0) {
                        html = `<tr class="">
                                    <td colspan="6">
                                        <div class="alert alert-info text-center mx-auto" role="alert">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16" style="margin-right: 6px;">
                                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                                            </svg>
                                            Aucune attestation n'a été trouvée
                                        </div>
                                    </td>
                                </tr>`

                        updateTable("pending", html);
                    }
                    else {
                        pendingCertificates = [];
                        data.Result.forEach((certificate, index) => {
                            //console.log("The certificate: "+JSON.stringify(certificate,null,2));
                            pendingCertificates.push({
                                CdmId: certificate.CdmId,
                                PositionNumber: index + 1,
                                RefNumber: certificate.RefNumber,
                                NomEtPrenom: `${certificate.Nom} ${certificate.Prenom}`,
                                //DateCreation: `${certificate.CreationDate}`
                                DateCreation: `${formatDate(Date(certificate.CreationDate).toString("o"))}`
                            });
                        });
                        updateTable("pending", "");
                        //console.log("Pending certificates table now: "+JSON.stringify(pendingCertificates,null,2));
                    };
                });

        }, 300))

        document.getElementById("validateCertificatesSearch").addEventListener("input", debounce(function () {
            let param = this.value.trim();
            let html = "";
            fetch(`/EcoCerAdmin/SearchValidateCertificates?param=${param}`)
                .then(response => response.json())
                .then(data => {
                    /*console.log("Validate Fetch result: "+JSON.stringify(data.result,null,2));
                    console.log("Result length: "+data.result.length);*/
                    if (data.Result.length === 0) {
                        html = `<tr class="">
                                    <td colspan="6">
                                        <div class="alert alert-info text-center mx-auto" role="alert">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16" style="margin-right: 6px;">
                                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0" />
                                            </svg>
                                            Aucune attestation n'a été trouvée
                                        </div>
                                    </td>
                                </tr>`

                        updateTable("validate", html);
                    }
                    else {
                        validateCertificates = [];
                        data.Result.forEach((certificate, index) => {
                            //console.log("The certificate: "+JSON.stringify(certificate,null,2));
                            validateCertificates.push({
                                CdmId: certificate.CdmId,
                                PositionNumber: index + 1,
                                RefNumber: certificate.RefNumber,
                                NomEtPrenom: `${certificate.Nom} ${certificate.Prenom}`,
                                //DateCreation: `${certificate.CreationDate}`
                                DateCreation: `${formatDate(Date(certificate.CreationDate).toString("o"))}`
                            });
                        });
                        updateTable("validate", "");
                        //console.log("Validate certificates table now: "+JSON.stringify(pendingCertificates,null,2));
                    };
                });

        }, 300));

        document.querySelectorAll(".validate-btn").forEach(function (btn) {
            let token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            btn.addEventListener("click", function (event) {
                event.stopPropagation();

                let row = btn.closest("tr");
                let certificateId = row.getAttribute("data-id")
                let certificateOwner = row.cells[2].textContent;

                console.log("CertificateId: ", certificateId);
                console.log("Certificate owner: ", certificateOwner);

                fetch("/EcoCerAdmin/ValidateCertificate", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded",
                        "RequestVerificationToken": token
                    },
                    body: `certificateId=${certificateId}`
                })
                    .then(response => response.json())
                    .then(data => {
                        console.log("Validate data content:", data);
                        if (data.success) {
                            console.log("Certificate validate successfully");
                            location.reload();
                        } else {
                            console.error("Validation failed")
                        }
                    })
                    .catch(error => console.error("Error: ", error));
            });
        });
    });


    document.addEventListener("DOMContentLoaded", function () {
        const sexeSelect = document.getElementById("sexe");
        const civiliteSelect = document.getElementById("civilite");

        function updateCivilityBasedOnSex() {
            if (sexeSelect.value === "Homme") {
                civiliteSelect.value = "Monsieur";
            } else if (sexeSelect.value === "Femme") {
                civiliteSelect.value = "Madame";
            } else {
                civiliteSelect.disabled = false;
            }
        }

        function updateSexBasedOnCivility() {
            if (civiliteSelect.value === "Monsieur") {
                sexeSelect.value = "Homme";
            } else if (civiliteSelect.value === "Madame") {
                sexeSelect.value = "Femme";
            } else {
                sexeSelect.disabled = false;
            }
        }

        sexeSelect.addEventListener("change", updateCivilityBasedOnSex);
        civiliteSelect.addEventListener("change", updateSexBasedOnCivility);

        updateCivilityBasedOnSex();
        updateSexBasedOnCivility();
    });

</script>

