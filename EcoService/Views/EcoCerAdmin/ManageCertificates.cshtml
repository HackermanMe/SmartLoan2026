<script>

    function openModal() {
        document.getElementById("editModal").style.display = "flex";
        document.body.classList.add("modal-open");
    }

    function closeModal() {
        document.getElementById("editModal").style.display = "none";
        document.body.classList.remove("modal-open");
    }

    //Chargement de l'attestation à modifier
    function editCertificate(certificateId) {
        //console.log("Got clicked again!");
        //console.log("Trying to load certificate with ID:"+certificateId);
        $.ajax({
            type: 'GET',
            url: 'GetCertificate',
            data: { id: certificateId },
            success: function (response) {
                //console.log("Certificate loaded successfully!");
                //console.log(response);
                const formattedDateRecrutement = formatDateToInputFormat(response.DateRecrutement);

                //Chargement des données dans le modal
                $('#cmdId').val(response.CdmId);
                $('#nom').val(response.Nom);
                $('#prenom').val(response.Prenom);
                $('#sexe').val(response.Sexe);
                $('#civilite').val(response.Civilite)
                $('#categoriePro').val(response.CategorieProfessionnelle)
                $('#dateRecrutement').val(formattedDateRecrutement)

            },
            error: function (xhr, status, error) {
                console.error("Error details: ", xhr.responseText, status, error);
                alert("Failed to load certificate details, please try again");
            }
        });
    }

    function getCertificatePdf(certificateId) {
        window.location.href = 'GetCertificatePdf/' + certificateId;
    }

    function searchQuery() {
        console.log("Change event triggered");

        var searchParameter = $("#certificateSearchInput").val();
        //console.log(searchParameter);
        $.ajax({
            url: '/EcoCerAdmin/SearchCertificate',
            type: 'GET',
            data: { parameter: searchParameter },
            success: function (response) {
                //console.log(response);
                $("#certificateList").html(response);
            },
            error: function (xhr, status, error) {
                console.error("Error details :", xhr.responseText, status, error)
                alert("Error during search!");
            }
        })
    }

    function validateCertificate() {
        let token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        let row = event.target.closest("tr");
        let certificateId = row.getAttribute("data-id");

        console.log("CertificateId: ", certificateId);

        fetch("/EcoCerAdmin/ValidateCertificate", {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "RequestVerificationToken": token
            },
            body: `certificateId=${certificateId}`
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log("Certificate validate successfully");
                    location.reload();
                } else {
                    console.error("Validation failed")
                }
            })
            .catch(error => console.error("Error: ", error));
    }




