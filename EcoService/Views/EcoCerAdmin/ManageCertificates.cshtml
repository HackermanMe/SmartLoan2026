
@{
    ViewBag.Title = "Modification Certificat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /*modal styles*/
    .searchBar-input {
        height: 40px;
        width: 450px !important;
        border-style: solid;
        border-width: 2px;
        border-color: #d0d5dd;
        border-radius: 9px;
        padding: 14px;
        margin-bottom: 20px;
    }

    body.modal-open {
        filter: blur(px);
        pointer-events: none;
    }

    .edit-modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: #F5F5F7;
        padding: 12px;
        border-radius: 10px;
        width: 700px;
        box-shadow: 0px 0px 10px rgba(0,0,0,0.3);
    }

    .close-btn {
        float: right;
        font-size: 27px;
        cursor: pointer;
        color: #B7B7B7;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .close-btn:hover {
            color: #000000;
        }

    /*.close-btn:active{
                    color:#000000;
                    transform:scale(0.5)
                }*/

    .custom-box {
        width: 1200px;
    }

    .modal-input {
        height: 40px;
        width: 320px;
        border-style: solid;
        border-width: 2px;
        border-color: #d0d5dd;
        border-radius: 9px;
        padding: 14px;
    }

    .modal-select {
        width: 320px;
        height: 40px;
        border-style: solid;
        border-width: 2px;
        border-radius: 9px;
        border-color: #d0d5dd;
        padding: 7px;
    }

    .modal-submit-button {
        background-color: #0082bb;
        width: 220px;
        height: 50px;
        border-style: none;
        border-radius: 9px;
        text-align: center;
        font-size: 1rem;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .modal-submit-button:active {
            background-color: #005f8c;
            transform: scale(0.95);
        }

        .modal-submit-button:hover {
            background-color: #007bb1;
        }

    .modal-cancel-button {
        background-color: #B7B7B7;
        width: 170px;
        height: 50px;
        border-style: none;
        border-radius: 9px;
        font-size: 1rem;
        text-decoration: none;
        text-align: center;
        display: inline-block;
        line-height: 50px;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .modal-cancel-button:active {
            background-color: #999999 !important;
            transform: scale(0.95);
        }

        .modal-cancel-button:hover {
            background-color: #B4B4B8;
        }

    a:hover {
        text-decoration: none;
        cursor: pointer;
    }

    select:focus {
        border-color: #c5cedb !important;
        border-width: 3px !important;
        outline: none !important;
    }


    /*ManageCertificates view styles*/
    .view-content-box {
        width: auto;
        border-color: #e5e5e5;
        border-radius: 8px;
        padding: 30px;
        /* background-color: #F5F5F7;*/
        box-shadow: 0 -4px 8px rgba(0, 0, 0, 0.1), -4px 0 8px rgba(0, 0, 0, 0.1), 0 4px 8px rgba(0,0,0,0.1);
    }

    .table-container {
        width: auto;
        border-color: #e5e5e5;
        border-radius: 8px;
        padding: 30px;
        margin-bottom: 20px;
        /* background-color: #F5F5F7;*/
        box-shadow: 0 -4px 8px rgba(0, 0, 0, 0.1), -4px 0 8px rgba(0, 0, 0, 0.1), 0 4px 8px rgba(0,0,0,0.1);
    }

    input:focus {
        border-color: #c5cedb;
        border-width: 3px;
        outline: none;
    }

    h2 {
        margin-bottom: 1rem;
        color: #333;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: bold;
        font-size: 1.2rem;
    }

    .custom-container {
        width: 300px;
        background-color: #F5F5F7;
        border-color: #e5e5e5;
        box-shadow: 5px 5px 5px rgb(0 0 0 / 0.1);
        border-radius: 8px;
    }
    /*Styled table for ManageCertificate page*/
    .styled-table {
        /*    border-collapse: collapse;*/
        margin-bottom: 2rem;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.2);
        width: 100%;
    }

        .styled-table thead tr {
            background-color: #0082bb;
            color: #ffffff;
            text-align: left;
        }

        .styled-table th, .styled-table td {
            padding: 12px 15px;
        }

        .styled-table tbody tr {
            border-bottom: 1px solid #dddddd;
        }

            .styled-table tbody tr:nth-of-type(even) {
                background-color: #f3f3f3;
            }

            .styled-table tbody tr:last-of-type {
                border-bottom: 2px solid #0082bb;
            }

            .styled-table tbody tr.active-row {
                font-weight: bold;
                color: #009879;
            }

    .table-hover tbody tr {
        cursor: pointer;
        transition: transform 0.2s ease-in-out, background 0.3s ease;
    }

        .table-hover tbody tr:hover {
            transform: scale(1.03);
            background: rgba(0, 123, 255, 0.1);
        }

        .table-hover tbody tr.clickable-row:active {
            transform: scale(0.97);
        }

    .download-btn {
        width: 100px;
        height: 35px;
        background-color: inherit;
        /*background-color: #0082bb;*/
        /*border-style: none;*/
        border-style: solid;
        border-width: 1px;
        border-color: #0082bb;
        text-align: center;
        color: #0082bb;
        transition: transform 0.2s ease, background-color 0.3s ease;
    }

        .download-btn:hover {
            background-color: #0082bb;
            color: white;
        }

        .download-btn:active {
            transform: scale(0.95);
        }
</style>

