<!--Formulaire de modification d'une attestation-->
<div id="editModal" class="edit-modal">
    <div class="modal-content">
        <div class="d-flex justify-content-end ">
            <span class="close-btn" onclick="closeModal()">&times;</span>
        </div>
        <h2 style="font-size:1.5rem;text-align:center;">Modifier une attestation</h2>

        <form method="post" action="@Url.Action("UpdateCertificate", "EcoCerAdmin")" id="editCertificateForm">
            @Html.AntiForgeryToken()
            <div class="d-flex justify-content-center align-items-center p-4 flex-column gap-1">
                <input type="hidden" name="CdmId" value="" id="cmdId" />
                <div class="d-flex flex-row gap-3">
                    <div class="d-flex flex-column gap-2">
                        <label>Nom:</label>
                        <input class="modal-input" id="nom" name="Nom" />
                        <span id="lastNameError" class="text-danger"></span>
                        @* <span asp-validation-for="CertificateToEdit.Nom" class="text-danger"></span> *@
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <label>Prénom:</label>
                        <input class="modal-input" id="prenom" name="Prenom" />
                        <span id="firstNameError" class="text-danger"></span>
                        @* <span asp-validation-for="CertificateToEdit.Prenom" class="text-danger"></span> *@
                    </div>
                </div>
                <div class="d-flex gap-3 flex-row">
                    <div class="d-flex flex-column gap-2">
                        <label class="">Genre</label>
                        <select class="modal-select" id="sexe" name="sexe">
                            @foreach (var sexe in Enum.GetValues(typeof(EcoService.Models.Enums.Sexe)).Cast<EcoService.Models.Enums.Sexe>())
                            {
                                <option value="@sexe">@sexe</option>
                            }
                        </select>
                        <span id="genderError" class="text-danger"></span>
                        @* <span asp-validation-for="CertificateToEdit.Sexe" class="text-danger"></span> *@
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <label class="">Civilité</label>
                        <select class="modal-select" id="civilite" name="civilite">
                            @foreach (var civilite in Enum.GetValues(typeof(EcoService.Models.Enums.Civilite)).Cast<EcoService.Models.Enums.Civilite>())
                            {
                                <option value="@civilite" selected="@civilite">@civilite</option>
                            }
                        </select>
                        <span id="civiliteError" class="text-danger"></span>
                    </div>
                </div>
                <div class="d-flex flex-column gap-2">
                    <label class="">Catégorie professionnelle:</label>
                    <input class="modal-input" id="categoriePro" name="CategorieProfessionnelle" style="width:650px;" />
                    <span id="catProError" class="text-danger"></span>
                    @* <span asp-validation-for="CertificateToEdit.Prenom" class="text-danger"></span> *@
                </div>
                <div class="d-flex flex-column gap-2">
                    <label class="">Date de recrutement:</label>
                    <input class="modal-input" type="date" id="dateRecrutement" name="DateRecrutement" style="width:650px;" />
                    <span id="dateReError" class="text-danger"></span>
                    @* <span asp-validation-for="CertificateToEdit.DateRecrutement" class="text-danger"></span> *@
                </div>
                <div class="d-flex flex-row gap-lg-5 mt-3">
                    @* asp-controller="EcoCerAdmin" asp-action="ManageCertificates" *@
                    <a onclick="closeModal();" class="modal-cancel-button text-white">Annuler</a>
                    <button id="confirmButton" type="submit" class="modal-submit-button text-white text-center">Confirmer</button>
                </div>
            </div>
        </form>
        @*<button id="validateButton" class="modal-submit-button text-white text-center">Valider</button> *@
    </div>
</div>


