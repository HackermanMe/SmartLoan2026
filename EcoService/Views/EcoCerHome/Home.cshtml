@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .home-welcome {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        padding: 40px;
    }
    .home-welcome h2 {
        font-weight: 600;
        color: #343a40;
        font-size: 1.5rem;
        margin-bottom: 6px;
    }
    .home-welcome p {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 0;
    }
    .app-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-top: 32px;
    }
    .app-tile {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 28px 16px;
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        text-decoration: none;
        color: #343a40;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .app-tile:hover {
        border-color: #0082bb;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        text-decoration: none;
        color: #2877c5;
    }
    .app-tile i {
        font-size: 1.6rem;
        color: #6c757d;
    }
    .app-tile:hover i {
        color: #0082bb;
    }
    .app-tile span {
        font-size: 0.85rem;
        font-weight: 600;
        text-align: center;
        line-height: 1.3;
    }
</style>

<div class="home-welcome">
    <h2>RH-Services</h2>
    <p>Bienvenue, veuillez selectionner une application.</p>

    <div class="app-grid">
        <a href="@Url.Action("StaffSimulation", "RHStaff")" class="app-tile">
            <i class="fas fa-chart-line"></i>
            <span>Simulateur de pret</span>
        </a>
        <a href="@Url.Action("GenerateCertificate", "EcoCerCertificate")" class="app-tile">
            <i class="fas fa-file-alt"></i>
            <span>Demande d'attestation de travail</span>
        </a>
        <a href="http://10.8.14.65:5234/EcoService/TypeRapport/PlanDeCarriere" class="app-tile">
            <i class="fas fa-briefcase"></i>
            <span>Plan de carriere</span>
        </a>
        <a href="@Url.Action("Index", "Trombinoscope")" class="app-tile">
            <i class="fas fa-sitemap"></i>
            <span>Trombinoscope</span>
        </a>
        <a href="https://teams/Pages/Default.aspx" class="app-tile">
            <i class="fas fa-globe"></i>
            <span>Portail Intranet</span>
        </a>
    </div>
</div>
