@using Ecoservice.Models;
@model LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>RH-Services | Authentification</title>
    <meta content='width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no' name='viewport'>
    <link rel="shortcut icon" type="image/png" href="~/Content/images/logos/favicon.ico" />
    <link rel="stylesheet" href="~/Content/css/styles.min.css" />
</head>

<body>
    @*Body Wrapper*@

    <div class="page-wrapper" id="main-wrapper" data-layout="vertical" data-navbarbg="skin6" data-sidebartype="full"
         data-sidebar-position="fixed" data-header-position="fixed">
        <div class="position-relative overflow-hidden radial-gradient min-vh-100 d-flex align-items-center justify-content-center">
            <div class="d-flex align-items-center justify-content-center w-100">
                <div class="row justify-content-center w-100">
                    <div class="col-md-8 col-lg-6 col-xxl-3">
                        <div class="card mb-0">
                            <div class="card-body">
                                <div href="" class="text-nowrap logo-img text-center d-block py-3 w-100">
                                    <img src="../assets/images/logos/télécharger.png" width="180" alt="">
                                </div>
                                <div class="d-block align-items-center justify-content-center">
                                    <h4 class="text-center">RH-Services</h4>
                                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <h1> <font style="font-weight: bold;font-size:25px;color: #04519b">CONNEXION </font></h1>
                                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                                        <div>
                                            <div class="mb-3">
                                                @Html.LabelFor(m => m.UserName, "Nom d'utilisateur", new { @class = "form-label", @id = "exampleInputEmail1", aria_describedby = "emailHelp" })
                                                @Html.TextBoxFor(m => m.UserName, new { autocomplete = "off", @class = "form-control" })
                                                @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })
                                            </div>
                                        </div>
                                        <div>
                                            <div class="mb-4">
                                                @Html.LabelFor(m => m.Password, "Mot de Passe", new { @class = "form-label", @id = "exampleInputPassword1" })
                                                @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
                                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                                            </div>
                                        </div>
                                        <div>
                                            <div>
                                                <input type="submit" name="connexion" id="connexion" value="Se connecter" class="btn btn-primary w-100 py-8 fs-4 mb-4 rounded-2" />
                                            </div>
                                        </div>
                                    }

                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/Content/libs/jquery/dist/jquery.min.js"></script>
    <script src="~/Content/libs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        var timeoutInMinutes=20; // 20 minutes
        setTimeout(function() {
            location.reload(); // Rafraîchir la page automatiquement
        }, timeoutInMinutes * 60 * 1000);
    </script> 

</body>
</html>
