                <div class="col-md-3"><div class="kpi-item"><div class="kpi-label">Total Assurance</div><div class="kpi-value" id="resumeTotalAssurance">-</div></div></div>
                <div class="col-md-3"><div class="kpi-item"><div class="kpi-label">Frais Dossier</div><div class="kpi-value" id="resumeFraisDossier">-</div></div></div>
