@model EcoService.Models.AmortissementInput

@{
    ViewData["Title"] = "Module Pret Bancaire";
}

<style>
    /* Onglets sobres */
    .tab-bar {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #dee2e6;
        margin-bottom: 20px;
    }
    .tab-bar .nav-link {
        border: none;
        background: none;
        font-weight: 500;
        font-size: 0.88rem;
        padding: 10px 20px;
        color: #6c757d;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.15s;
    }
    .tab-bar .nav-link:hover { color: #333; }
    .tab-bar .nav-link.active {
        color: #0d6efd;
        border-bottom-color: #0d6efd;
        font-weight: 600;
    }

    /* Sous-sections */
    .field-group {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 6px;
        padding: 16px;
        margin-top: 16px;
    }
    .field-group-title {
        font-size: 0.82rem;
        font-weight: 600;
        color: #495057;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 14px;
    }

    /* Resume items */
    .kpi-item {
        padding: 8px 0;
    }
    .kpi-item .kpi-label { font-size: 0.78rem; color: #6c757d; }
    .kpi-item .kpi-value { font-size: 0.95rem; font-weight: 600; color: #212529; }

    /* Tableau */
    #amortissementTable thead th {
        background: #343a40;
        color: #fff;
        font-size: 0.78rem;
        padding: 8px 10px;
        font-weight: 600;
        border: none;
    }
    #amortissementTable tbody td {
        font-size: 0.8rem;
        padding: 5px 10px;
        border-bottom: 1px solid #eee;
    }
    #amortissementTable tbody tr:nth-child(even) { background: #f8f9fa; }
    #amortissementTable tbody tr:hover { background: #e9ecef; }
    #amortissementTable tfoot td {
        background: #343a40;
        color: #fff;
        font-weight: 700;
        padding: 8px 10px;
        font-size: 0.82rem;
    }

    /* Barre actions */
    .action-bar {
        border-top: 1px solid #dee2e6;
        padding-top: 16px;
        margin-top: 20px;
    }
</style>

<h5 class="fw-semibold mb-1">Module Pret Bancaire</h5>
<p class="text-muted mb-4" style="font-size:0.85rem;">Simulation de credit avec tableau d'amortissement</p>

@* ALERTES *@
<div id="alertesContainer" style="display:none;" class="mb-3">
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0 fw-semibold">Alertes et Conformite</h6>
            <span class="badge bg-warning text-dark" id="alertesCount">0</span>
        </div>
        <div id="alertesList"></div>
    </div>
</div>

@* FORMULAIRE *@
<div class="card">
    <div class="card-body p-4">
        <form id="amortissementForm">

            <div class="tab-bar" id="pretTabs" role="tablist">
                <button class="nav-link active tab-btn" id="pill-pret-tab" data-bs-toggle="pill" data-bs-target="#tabPret" data-tab="tabPret" type="button" role="tab">Pret</button>
                <button class="nav-link tab-btn" id="pill-client-tab" data-bs-toggle="pill" data-bs-target="#tabClient" data-tab="tabClient" type="button" role="tab">Client</button>
                <button class="nav-link tab-btn" id="pill-encours-tab" data-bs-toggle="pill" data-bs-target="#tabEncours" data-tab="tabEncours" type="button" role="tab">Encours <span class="badge bg-secondary" id="encoursCount">0</span></button>
                <button class="nav-link tab-btn" id="pill-options-tab" data-bs-toggle="pill" data-bs-target="#tabAvance" data-tab="tabAvance" type="button" role="tab">Options</button>
            </div>

            <div class="tab-content" id="pretTabsContent">

                @* ONGLET PRET *@
                <div class="tab-pane fade show active" id="tabPret" role="tabpanel">
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="montantPret" name="montantPret" required min="1" step="1" placeholder=" ">
                                <label for="montantPret">Montant du Pret <span class="text-danger">*</span></label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="tauxAnnuel" name="tauxAnnuel" required min="0" max="100" step="0.01" placeholder=" ">
                                <label for="tauxAnnuel">Taux Annuel HT (%) <span class="text-danger">*</span></label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="text" class="form-control bg-light" id="tauxTTC" readonly placeholder=" " title="Calcule: Taux HT x (1 + TAF)">
                                <label>Taux TTC (%)</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="nombreEcheances" name="nombreEcheances" required min="1" max="600" placeholder=" ">
                                <label for="nombreEcheances">Nombre d'Echeances <span class="text-danger">*</span></label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="periodicite" name="periodicite">
                                    <option value="1" selected>Mensuel</option>
                                    <option value="3">Trimestriel</option>
                                    <option value="6">Semestriel</option>
                                    <option value="12">Annuel</option>
                                </select>
                                <label for="periodicite">Periodicite</label>
                            </div>
                        </div>
                        <div class="col-md-1">
                            <div class="form-floating">
                                <input type="date" class="form-control" id="dateDebut" name="dateDebut" required placeholder=" ">
                                <label for="dateDebut">1ere Ech. <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="date" class="form-control" id="dateDeblocage" name="dateDeblocage" placeholder=" ">
                                <label for="dateDeblocage">Date Deblocage</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="input-group">
                                <div class="form-floating flex-grow-1">
                                    <input type="number" class="form-control" id="fraisDossier" name="fraisDossier" min="0" step="1" value="0" placeholder=" ">
                                    <label for="fraisDossier">Frais Dossier (1.5%)</label>
                                </div>
                                <button type="button" class="btn btn-outline-secondary" id="btnCalcFrais" title="Calculer 1.5%">%</button>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="objetCredit" name="objetCredit">
                                    <option value="">-- Selectionnez --</option>
                                    <option value="Achat vehicule">Achat vehicule</option>
                                    <option value="Travaux">Travaux</option>
                                    <option value="Scolaire">Scolaire</option>
                                    <option value="Tresorerie">Tresorerie</option>
                                    <option value="Rachat credits">Rachat de credits</option>
                                    <option value="Equipement">Equipement</option>
                                    <option value="Autre">Autre</option>
                                </select>
                                <label for="objetCredit">Objet du Credit</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="tauxTAF" name="tauxTAF" min="0" max="100" step="0.01" value="10">
                                <label for="tauxTAF">TAF (%)</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="modeRemboursement" name="modeRemboursement">
                                    <option value="1" selected>Echeances constantes</option>
                                    <option value="2">Amortissement constant</option>
                                    <option value="3">In Fine</option>
                                </select>
                                <label for="modeRemboursement">Mode Remboursement</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="conventionJours" name="conventionJours">
                                    <option value="1" selected>30/360</option>
                                    <option value="2">Exact/365</option>
                                </select>
                                <label for="conventionJours">Convention Jours</label>
                            </div>
                        </div>
                    </div>

                    <div class="field-group">
                        <div class="field-group-title">Capacite d'endettement</div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="salaireMensuel" name="salaireMensuel" min="0" step="1" value="0" placeholder=" ">
                                    <label for="salaireMensuel">Salaire Mensuel</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <select class="form-select" id="profilClient" name="profilClient">
                                        <option value="1">Salarie</option>
                                        <option value="4">Retraite</option>
                                    </select>
                                    <label for="profilClient">Profil Client</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="autresCharges" name="autresCharges" min="0" step="1" value="0" placeholder=" ">
                                    <label for="autresCharges">Autres Charges</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-muted" style="font-size:0.78rem;">Capacite Max</label>
                                <div class="fw-semibold">
                                    <span id="capaciteMaxDisplay">-</span>
                                    <small class="text-muted" id="tauxEndettementMaxDisplay">(-)</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ONGLET CLIENT *@
                <div class="tab-pane fade" id="tabClient" role="tabpanel">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <div class="input-group">
                                <div class="form-floating flex-grow-1">
                                    <input type="text" class="form-control" id="numeroCompte" name="numeroCompte" placeholder=" ">
                                    <label for="numeroCompte">Numero de Compte <span class="text-danger">*</span></label>
                                </div>
                                <button type="button" class="btn btn-outline-secondary" id="btnRechercheCompte" title="Rechercher"><i class="fas fa-search"></i></button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control bg-light" id="intituleCompte" name="intituleCompte" readonly placeholder=" ">
                                <label for="intituleCompte">Intitule du Compte</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientNom" name="clientNom" placeholder=" ">
                                <label for="clientNom">Nom <span class="text-danger">*</span></label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientPrenom" name="clientPrenom" placeholder=" ">
                                <label for="clientPrenom">Prenom <span class="text-danger">*</span></label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="date" class="form-control" id="clientDateNaissance" name="clientDateNaissance" placeholder=" ">
                                <label for="clientDateNaissance">Date de Naissance</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientLieuNaissance" name="clientLieuNaissance" placeholder=" ">
                                <label for="clientLieuNaissance">Lieu de Naissance</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientAdresse" name="clientAdresse" placeholder=" ">
                                <label for="clientAdresse">Adresse</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientVille" name="clientVille" placeholder=" ">
                                <label for="clientVille">Ville</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="tel" class="form-control" id="clientTelephone" name="clientTelephone" placeholder=" ">
                                <label for="clientTelephone">Telephone</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="situationMatrimoniale" name="situationMatrimoniale">
                                    <option value="1">Celibataire</option>
                                    <option value="2">Marie(e)</option>
                                    <option value="3">Divorce(e)</option>
                                    <option value="4">Veuf(ve)</option>
                                    <option value="5">Union libre</option>
                                </select>
                                <label for="situationMatrimoniale">Situation Matrimoniale</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientProfession" name="clientProfession" placeholder=" ">
                                <label for="clientProfession">Profession</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="clientEmployeur" name="clientEmployeur" placeholder=" ">
                                <label for="clientEmployeur">Employeur</label>
                            </div>
                        </div>
                    </div>

                    <div class="field-group">
                        <div class="field-group-title">Piece d'identite</div>
                        <div class="row g-3">
                            <div class="col-md-2">
                                <div class="form-floating">
                                    <select class="form-select" id="typePieceIdentite" name="typePieceIdentite">
                                        <option value="1">CNI</option>
                                        <option value="2">Passeport</option>
                                        <option value="3">Carte de sejour</option>
                                        <option value="4">Permis de conduire</option>
                                    </select>
                                    <label for="typePieceIdentite">Type</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="numeroPieceIdentite" name="numeroPieceIdentite" placeholder=" ">
                                    <label for="numeroPieceIdentite">Numero</label>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-floating">
                                    <input type="date" class="form-control" id="dateDelivrancePiece" name="dateDelivrancePiece" placeholder=" ">
                                    <label for="dateDelivrancePiece">Date Delivrance</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="lieuDelivrancePiece" name="lieuDelivrancePiece" placeholder=" ">
                                    <label for="lieuDelivrancePiece">Lieu Delivrance</label>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-floating">
                                    <input type="date" class="form-control" id="dateExpirationPiece" name="dateExpirationPiece" placeholder=" ">
                                    <label for="dateExpirationPiece">Date Expiration</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ONGLET ENCOURS *@
                <div class="tab-pane fade" id="tabEncours" role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-semibold" style="font-size:0.9rem;">Credits existants du client (max 6)</span>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnAjouterEncours">+ Ajouter</button>
                    </div>

                    <div id="encoursList"></div>

                    <div id="encoursResume" style="display:none;" class="field-group mt-3">
                        <div class="row">
                            <div class="col-md-2"><span class="text-muted" style="font-size:0.78rem;">Total encours actifs</span><br><strong id="totalEncoursActifs">0</strong></div>
                            <div class="col-md-2"><span class="text-muted" style="font-size:0.78rem;">Total mensualites</span><br><strong id="totalMensualitesEncours">0</strong></div>
                            <div class="col-md-3"><span class="text-muted" style="font-size:0.78rem;">Encours a racheter</span><br><strong class="text-danger" id="totalEncoursARacheter">0</strong></div>
                            <div class="col-md-2"><span class="text-muted" style="font-size:0.78rem;">Commission rachat (2%)</span><br><strong id="totalCommissionRachat">0</strong></div>
                            <div class="col-md-3"><span class="text-muted" style="font-size:0.78rem;">Montant net disponible</span><br><strong class="text-success" id="montantNetDisponible">0</strong></div>
                        </div>
                    </div>

                    <div id="encoursTemplate" style="display:none;">
                        <div class="encours-card card mb-2" data-index="0">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-semibold encours-numero" style="font-size:0.88rem;">Encours #1</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input encours-racheter" id="racheter0">
                                            <label class="form-check-label" for="racheter0">A racheter</label>
                                        </div>
                                        <button type="button" class="btn btn-outline-danger btn-sm btn-supprimer-encours" title="Supprimer">&times;</button>
                                    </div>
                                </div>
                                <div class="row g-3 encours-grid">
                                    <div class="col-md-3">
                                        <div class="form-floating">
                                            <input type="text" class="form-control encours-banque" placeholder=" ">
                                            <label>Banque/Reference</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-floating">
                                            <input type="number" class="form-control encours-solde" min="0" step="1" placeholder=" ">
                                            <label>Solde Restant <span class="text-danger">*</span></label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-floating">
                                            <input type="number" class="form-control encours-mensualite" min="0" step="1" placeholder=" ">
                                            <label>Mensualite</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-floating">
                                            <input type="number" class="form-control encours-echeances" min="0" max="600" placeholder=" ">
                                            <label>Echeances Rest.</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ONGLET OPTIONS *@
                <div class="tab-pane fade" id="tabAvance" role="tabpanel">
                    <div class="row g-3 mb-3">
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="typeTaux" name="typeTaux">
                                    <option value="1" selected>Proportionnel</option>
                                    <option value="2">Actuariel</option>
                                </select>
                                <label for="typeTaux">Type de Taux</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <select class="form-select" id="baseAssurance" name="baseAssurance">
                                    <option value="1" selected>Capital Initial</option>
                                    <option value="2">Capital Restant Du</option>
                                </select>
                                <label for="baseAssurance">Base Assurance</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="primeAssuranceClient" name="primeAssuranceClient" min="0" step="1" value="0" placeholder=" ">
                                <label for="primeAssuranceClient">Prime Assurance Client</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="commissionETG" name="commissionETG" min="0" step="1" value="0" placeholder=" ">
                                <label for="commissionETG">Commission ETG</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="text" class="form-control bg-light" id="primeAssuranceGTAC2A" readonly placeholder=" ">
                                <label>Prime GTA C2A</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="assuranceFixe" name="assuranceFixe" min="0" step="1" value="0" placeholder=" ">
                                <label for="assuranceFixe">Assurance/Echeance</label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="teg" name="teg" min="0" max="100" step="0.01" value="0" placeholder=" ">
                                <label for="teg">TEG Manuel (%)</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input type="number" class="form-control" id="tauxCommissionRachat" name="tauxCommissionRachat" min="0" max="10" step="0.1" value="2">
                                <label for="tauxCommissionRachat">Commission Rachat (%)</label>
                            </div>
                        </div>
                    </div>

                    <div class="field-group mb-3">
                        <div class="field-group-title">Differe de paiement</div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="differeEcheances" name="differeEcheances" min="0" max="120" value="0">
                                    <label for="differeEcheances">Nombre d'Echeances</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <select class="form-select" id="typeDiffere" name="typeDiffere">
                                        <option value="1" selected>Partiel (interets payes)</option>
                                        <option value="2">Total (interets capitalises)</option>
                                    </select>
                                    <label for="typeDiffere">Type de Differe</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="field-group">
                        <div class="field-group-title">Remboursement anticipe</div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="echeanceRA" name="echeanceRA" min="0" max="600" value="0" placeholder="0 = aucun">
                                    <label for="echeanceRA">A l'Echeance N</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="montantRA" name="montantRA" min="0" step="1" value="0" placeholder="0 = total">
                                    <label for="montantRA">Montant RA</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="number" class="form-control" id="tauxPenaliteRA" name="tauxPenaliteRA" min="0" max="100" step="0.01" value="3">
                                    <label for="tauxPenaliteRA">Penalite (%)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="action-bar d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-light" id="btnReset">Reinitialiser</button>
                <button type="submit" class="btn btn-dark" id="btnCalculer">
                    <span class="btn-text">Calculer le Tableau</span>
                    <span class="btn-loader" style="display:none;">Calcul en cours...</span>
                </button>
            </div>
        </form>
    </div>
</div>

@* RESULTATS *@
