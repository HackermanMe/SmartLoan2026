                    <div class="col-md-2"><div class="kpi-item"><div class="kpi-label">Salaire</div><div class="kpi-value" id="resumeSalaire">-</div></div></div>
                    <div class="col-md-2"><div class="kpi-item"><div class="kpi-label">Taux Max Autorise</div><div class="kpi-value" id="resumeTauxMax">-</div></div></div>
