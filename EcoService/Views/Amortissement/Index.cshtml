                <div class="col-md-3" id="resumeNetContainer" style="display:none;"><div class="kpi-item"><div class="kpi-label">Montant Net Dispo.</div><div class="kpi-value text-success" id="resumeMontantNet">-</div></div></div>
                <div class="col-md-3"><div class="kpi-item" style="background:#f8f9fa; padding:8px 12px; border-radius:4px;"><div class="kpi-label">Cout Total Credit</div><div class="kpi-value" id="resumeCoutTotal">-</div></div></div>
                <div class="col-md-3"><div class="kpi-item"><div class="kpi-label">TEG Calcule</div><div class="kpi-value" id="resumeTEGCalcule">-</div></div></div>
