            <div class="row g-3">
                <div class="col-md-3"><div class="kpi-item"><div class="kpi-label">Montant du pret</div><div class="kpi-value" id="resumeMontant">-</div></div></div>
                <div class="col-md-3"><div class="kpi-item"><div class="kpi-label">Taux nominal</div><div class="kpi-value" id="resumeTaux">-</div></div></div>
