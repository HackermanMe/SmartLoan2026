
@{
    ViewBag.Title = "Index";
}

@using GridMvc.Html

@model IEnumerable<DALE.personcip>



@Html.Grid(Model).Columns(columns =>
{
    columns.Add(c => c.Date_Open);
    columns.Add(c => c.Date_Cloture);
    //columns.Add(c => c.code);
    columns.Add(c => c.CodeClient);
    columns.Add(c => c.Rib);
    columns.Add(c => c.Cle_Rib);
    columns.Add(c => c.Nom);
    columns.Add(c => c.Prenoms);
    columns.Add(c => c.LieuNaissance);
    columns.Add(c => c.DateNaissance);
    columns.Add(c => c.NomMari);
    columns.Add(c => c.Nom_mere);
    columns.Add(c => c.Nationalite);
    columns.Add(c => c.Sexe);
    columns.Add(c => c.ResidentUEMOA);
    columns.Add(c => c.NumCNI);
    columns.Add(c => c.Responsable);
    columns.Add(c => c.Mandataire);
    columns.Add(c => c.Adresse);
    columns.Add(c => c.CodePays);
    columns.Add(c => c.Ville);



});



